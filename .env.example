# ========================================
# Analyticatech - Environment Configuration
# ========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ----------------------------------------
# SUPABASE (Required for backend)
# ----------------------------------------
# Get these from: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ----------------------------------------
# ANALYTICS - PostHog (Optional)
# ----------------------------------------
# Analytics are disabled by default until user consent
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# ----------------------------------------
# SECURITY - Cloudflare Turnstile (Optional)
# ----------------------------------------
# CAPTCHA for contact form protection
# Get your site key from: https://dash.cloudflare.com/?to=/:account/turnstile
# Test key below works in development only
VITE_TURNSTILE_SITE_KEY=

# ----------------------------------------
# ERROR TRACKING - Sentry (Optional)
# ----------------------------------------
# Production error monitoring
VITE_SENTRY_DSN=

# ----------------------------------------
# APPLICATION MODE
# ----------------------------------------
# Set to true to use mock data instead of Supabase
VITE_DEGRADED_MODE=false

# ----------------------------------------
# SECURITY NOTES
# ----------------------------------------
# 1. All VITE_ prefixed vars are exposed to the browser
# 2. Never put secrets (API keys with write access) in VITE_ vars
# 3. Supabase anon key is safe to expose (it has RLS protection)
# 4. Turnstile site key is public (different from secret key)
